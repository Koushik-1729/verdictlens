# =============================================================================
# VerdictLens — Environment Configuration
# Copy this file to .env and adjust as needed:  cp .env.example .env
# =============================================================================

# --- API Server ---------------------------------------------------------------
VERDICTLENS_HOST=0.0.0.0
VERDICTLENS_PORT=8000
VERDICTLENS_DEBUG=false
# Restrict to your frontend origin in production. Comma-separated list.
# For self-hosted: http://yourdomain.com — for local dev: http://localhost:3000
VERDICTLENS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Uncomment and set a key to require X-VerdictLens-Key header on /traces routes.
# Leave commented out for open mode (default for self-hosted installs).
# VERDICTLENS_API_KEY=change-me-to-a-real-secret

# --- PostgreSQL (transactional: workspaces, API keys, prompts, alerts) --------
# Default assumes a local PostgreSQL instance. Override for remote/cloud PG.
# If using the bundled container (docker compose --profile bundled-pg up),
# use: postgresql://postgres:postgres@postgres:5432/verdictlens
VERDICTLENS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentlens

# --- ClickHouse (analytical: traces, spans, metrics) -------------------------
VERDICTLENS_CH_HOST=clickhouse
VERDICTLENS_CH_PORT=8123
VERDICTLENS_CH_USER=default
VERDICTLENS_CH_PASSWORD=
VERDICTLENS_CH_DATABASE=verdictlens
VERDICTLENS_CH_SECURE=false

# --- Redis (used for multi-replica WebSocket pub/sub) -------------------------
VERDICTLENS_REDIS_URL=redis://redis:6379/0

# --- Frontend -----------------------------------------------------------------
VITE_API_URL=http://localhost:8000

# --- LLM keys (used only by example scripts, not required for the platform) ---
# Groq — FREE tier, get a key at https://console.groq.com/keys
GROQ_API_KEY=
# xAI Grok — https://console.x.ai
XAI_API_KEY=
# OpenAI — https://platform.openai.com
OPENAI_API_KEY=
# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Google — https://aistudio.google.com
GOOGLE_API_KEY=
# NVIDIA NIM — FREE tier, get a key at https://build.nvidia.com
NVIDIA_API_KEY=
